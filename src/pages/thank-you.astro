---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank You - Truck Tire Service On The Go">
  <div class="min-h-screen flex items-center justify-center bg-slate-50 px-4">
    <div class="bg-white rounded-2xl shadow-xl p-8 sm:p-12 max-w-lg w-full text-center">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <i class="fa-solid fa-circle-check text-4xl text-green-500"></i>
      </div>
      <h1 class="font-display font-black text-2xl sm:text-3xl uppercase text-brand-dark mb-4">We Got Your Request!</h1>
      <p class="text-slate-600 text-base sm:text-lg mb-6">
        Our team is reviewing your info and will call you back within minutes. If it's an emergency, don't wait — call us directly.
      </p>
      <a href="tel:+18888044825" class="bg-brand-red hover:bg-red-700 text-white px-8 py-4 rounded-lg font-black text-lg uppercase shadow-xl shadow-red-600/30 transition-all hover:-translate-y-1 inline-flex items-center gap-3 min-h-[56px]">
        <i class="fa-solid fa-phone-volume"></i> Call (888) 804-4825
      </a>
      <div class="mt-8">
        <a href="/" class="text-brand-red font-bold hover:underline text-sm uppercase tracking-wide">
          <i class="fa-solid fa-arrow-left mr-1"></i> Back to Home
        </a>
      </div>
    </div>
  </div>
</Layout>
