---
import ServicePage from "../../layouts/ServicePage.astro";

const benefits = [
  "On-site tire changes for semi-trucks, dump trucks, box trucks, and all commercial vehicles",
  "We carry a wide inventory of commercial tire sizes — no waiting for parts",
  "Available 24/7 including nights, weekends, and holidays",
  "Arrive within 30 minutes to your location or job site",
  "Licensed, insured technicians with heavy-duty equipment",
  "Serving the entire tri-state area within a 250-mile radius",
];

const faqs = [
  { q: "How fast can you get to my truck?", a: "We dispatch immediately and typically arrive within 30 minutes anywhere in the tri-state area. For locations outside our immediate zone, we provide an ETA when you call." },
  { q: "What types of commercial trucks do you service?", a: "We service all commercial vehicles including semi-trucks, 18-wheelers, dump trucks, box trucks, flatbeds, refrigerated trailers, and more. If it has tires, we can handle it." },
  { q: "Do you carry tires or do I need to provide them?", a: "We carry a large inventory of the most common commercial tire sizes on our service trucks. For specialized sizes, we can source and deliver within hours." },
  { q: "What does a roadside commercial tire change cost?", a: "Pricing depends on the tire size, type, and your location. Call us at (347) 668-5874 for an immediate quote — no hidden fees, no surprises." },
  { q: "Do I need a membership or contract?", a: "No. We help anyone who calls — no membership, no sign-up, no contract. Just call and we show up." },
];

const relatedServices = [
  { name: "Heavy Equipment Tires", href: "/services/heavy-equipment-tires", icon: "fa-solid fa-gears" },
  { name: "Battery Delivery", href: "/services/battery-delivery", icon: "fa-solid fa-car-battery" },
  { name: "Fuel Delivery", href: "/services/fuel-delivery", icon: "fa-solid fa-gas-pump" },
  { name: "Jump Starts", href: "/services/jump-starts", icon: "fa-solid fa-bolt" },
];

const details = `
<p class="mb-4">When your commercial truck blows a tire on the highway or at the job site, every minute of downtime costs you money. <strong>Truck Tire Service On The Go</strong> is the tri-state area's trusted mobile tire service for commercial vehicles.</p>

<h3 class="font-display font-bold text-lg uppercase text-brand-dark mt-6 mb-3">1. You Call — We Roll</h3>
<p class="mb-4">Call <a href="tel:+13476685874" class="text-brand-red font-bold hover:underline">(347) 668-5874</a> and tell us your location and tire size. We dispatch a fully equipped service truck immediately.</p>

<h3 class="font-display font-bold text-lg uppercase text-brand-dark mt-6 mb-3">2. We Arrive in 30 Minutes or Less</h3>
<p class="mb-4">Our technicians come to you — whether you're on the shoulder of the NJ Turnpike, at a warehouse dock, or on a construction site. No need to move your vehicle or wait for a tow.</p>

<h3 class="font-display font-bold text-lg uppercase text-brand-dark mt-6 mb-3">3. Back on the Road Fast</h3>
<p>We handle the full tire change on-site with commercial-grade equipment. Most jobs are completed in under an hour so you can get back to work with minimal disruption.</p>
`;
---

<ServicePage
  title="Commercial Truck Tire Service | 24/7 Mobile Tire Change | Truck Tire Service On The Go"
  description="24/7 mobile commercial truck tire service in NY, NJ, and the tri-state area. On-site tire changes for semi-trucks, dump trucks, box trucks. 30-min response. Call (347) 668-5874."
  headline='Commercial <span class="text-brand-red">Truck Tire</span> Service'
  subheadline="Blowout on the highway? Flat at the job site? We bring the tires and tools to you. On-site commercial tire changes for semi-trucks, dump trucks, box trucks, and all commercial vehicles — 24/7."
  heroIcon="fa-solid fa-truck-monster"
  benefits={benefits}
  details={details}
  faqs={faqs}
  relatedServices={relatedServices}
/>
